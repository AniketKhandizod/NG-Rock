# Copy to .env and adjust, or set these in the shell / Railway UI.
# Never commit a real .env to git.

# Required in production (Railway Variables)
API_KEY=use-a-long-random-string-in-production

# Optional: defaults to 3000 locally; Railway sets PORT automatically
# PORT=3000

# Optional: use production checks (requires API_KEY)
# NODE_ENV=production
